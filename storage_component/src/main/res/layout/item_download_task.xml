<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="data"
            type="com.xyoye.data_component.entity.DownloadTaskEntity" />
    </data>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        app:cardBackgroundColor="@color/item_bg_color"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <TextView
                android:id="@+id/file_name_tv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_black"
                android:textSize="15sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="video.mp4" />

            <ProgressBar
                android:id="@+id/progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_marginTop="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/file_name_tv" />

            <TextView
                android:id="@+id/progress_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_theme"
                android:textSize="13sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/progress_bar"
                tools:text="50%" />

            <TextView
                android:id="@+id/size_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:textColor="@color/text_gray"
                android:textSize="13sp"
                app:layout_constraintBottom_toBottomOf="@+id/progress_tv"
                app:layout_constraintStart_toEndOf="@+id/progress_tv"
                app:layout_constraintTop_toTopOf="@+id/progress_tv"
                tools:text="50MB / 100MB" />

            <TextView
                android:id="@+id/speed_tv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:textColor="@color/text_theme"
                android:textSize="13sp"
                app:layout_constraintBottom_toBottomOf="@+id/progress_tv"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/size_tv"
                app:layout_constraintTop_toTopOf="@+id/progress_tv"
                tools:text="45.2 MB/s" />

            <TextView
                android:id="@+id/status_tv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_gray"
                android:textSize="12sp"
                app:layout_constraintEnd_toStartOf="@+id/eta_tv"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/progress_tv"
                tools:text="下载中" />

            <TextView
                android:id="@+id/eta_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_gray"
                android:textSize="12sp"
                app:layout_constraintBottom_toBottomOf="@+id/status_tv"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/status_tv"
                tools:text="剩余 2分30秒" />

            <LinearLayout
                android:id="@+id/action_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/status_tv">

                <TextView
                    android:id="@+id/pause_bt"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingHorizontal="16dp"
                    android:text="暂停"
                    android:textColor="@color/text_theme"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/cancel_bt"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingHorizontal="16dp"
                    android:text="取消"
                    android:textColor="@color/text_red"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/retry_bt"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingHorizontal="16dp"
                    android:text="重试"
                    android:textColor="@color/text_theme"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/open_bt"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingHorizontal="16dp"
                    android:text="打开"
                    android:textColor="@color/text_theme"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/clear_record_bt"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingHorizontal="16dp"
                    android:text="清除记录"
                    android:textColor="@color/text_gray"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/delete_bt"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:minWidth="72dp"
                    android:paddingHorizontal="16dp"
                    android:text="删除文件"
                    android:textColor="@color/text_gray"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</layout>