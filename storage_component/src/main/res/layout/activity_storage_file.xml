<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="com.xyoye.storage_component.ui.activities.storage_file.StorageFileViewModel" />

        <variable
            name="viewModel"
            type="com.xyoye.storage_component.ui.activities.storage_file.StorageFileViewModel" />
    </data>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinator_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appbar_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/item_bg_color"
            app:elevation="0dp">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?android:attr/actionBarSize"
                app:layout_scrollFlags="scroll|enterAlways"
                app:subtitleTextAppearance="@style/Theme.DanDanPlay.Toolbar.Subtitle"
                app:titleTextColor="@color/text_theme" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/path_rv"
                android:layout_width="match_parent"
                android:layout_height="48dp" />

        </com.google.android.material.appbar.AppBarLayout>

        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/storage_file_scroll_behavior"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/toolbar_layout" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/scroll_to_top_bt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|bottom"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="32dp"
            android:contentDescription="回到顶部"
            android:focusable="true"
            android:src="@drawable/ic_arrow_up_white"
            android:visibility="gone"
            android:alpha="0.0"
            app:backgroundTint="@color/float_button_bg_color"
            app:borderWidth="0dp"
            app:elevation="3dp"
            app:fabCustomSize="52dp"
            app:maxImageSize="26dp"
            app:rippleColor="@color/float_button_ripple_color" />

        <com.xyoye.common_component.weight.ExpandableFabMenu
            android:id="@+id/expandable_fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|bottom"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="96dp" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>