<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="android.view.View" />
        <import type="com.xyoye.user_component.ui.activities.thumbnail_setting.ThumbnailSettingViewModel" />

        <variable
            name="viewModel"
            type="com.xyoye.user_component.ui.activities.thumbnail_setting.ThumbnailSettingViewModel" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/layout_bg_color"
        android:orientation="vertical">

        <include layout="@layout/layout_toolbar" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/background_item_corner"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/background_item_press_corner"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="生成缩略图"
                                android:textColor="@color/text_black"
                                android:textSize="16sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="开启后将为选中的媒体文件生成缩略图"
                                android:textColor="@color/text_gray"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="@{viewModel.generateThumbnail}"
                            android:onCheckedChanged="@{(buttonView, isChecked) -> viewModel.onGenerateThumbnailChanged(isChecked)}"
                            app:theme="@style/Theme.DanDanPlay.SwitchCompat" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/file_type_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/background_item_press_corner"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:visibility="@{viewModel.generateThumbnail ? View.VISIBLE : View.GONE}">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="文件类型"
                            android:textColor="@color/text_black"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="仅为选中的文件类型生成缩略图"
                            android:textColor="@color/text_gray"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <CheckBox
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:checked="@{viewModel.generateForImage}"
                                android:onCheckedChanged="@{(buttonView, isChecked) -> viewModel.onGenerateForImageChanged(isChecked)}"
                                android:text="图片" />

                            <CheckBox
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:checked="@{viewModel.generateForVideo}"
                                android:onCheckedChanged="@{(buttonView, isChecked) -> viewModel.onGenerateForVideoChanged(isChecked)}"
                                android:text="视频" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/save_dir_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/background_item_press_corner"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:visibility="@{viewModel.generateThumbnail &amp;&amp; viewModel.generateForVideo ? View.VISIBLE : View.GONE}">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="保存缩略图到服务器"
                                android:textColor="@color/text_black"
                                android:textSize="16sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="开启后视频缩略图将保存到视频目录下的「./thumb」文件夹，以优化多设备访问性能"
                                android:textColor="@color/text_gray"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="@{viewModel.saveInSameDir}"
                            android:onCheckedChanged="@{(buttonView, isChecked) -> viewModel.onSaveInSameDirChanged(isChecked)}"
                            app:theme="@style/Theme.DanDanPlay.SwitchCompat" />
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/server_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/background_item_corner"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:text="服务器缩略图"
                        android:textColor="@color/text_black"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="8dp"
                        android:text="单独控制每台远程存储服务器的缩略图开关"
                        android:textColor="@color/text_gray"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:id="@+id/server_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>
</layout>
