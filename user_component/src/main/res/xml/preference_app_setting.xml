<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">



    <PreferenceCategory android:title="设置">

        <ListPreference
            android:key="view_mode"
            android:title="默认视图模式"
            android:summary="设置文件浏览页面的默认视图模式"
            android:entries="@array/view_mode_entries"
            android:entryValues="@array/view_mode_values"
            app:icon="@drawable/ic_app_setting_view_mode" />

        <SwitchPreference
            android:key="hide_file"
            android:summary="在选择文件时，显示系统隐藏文件"
            android:title="显示隐藏文件"
            app:icon="@drawable/ic_app_setting_hide_file" />

        <Preference
            android:key="dark_mode"
            android:title="深色模式"
            app:icon="@drawable/ic_dark_mode_system" />

        <Preference
            android:key="backup_manager"
            android:title="备份管理"
            android:summary="导出或导入软件配置信息"
            app:icon="@drawable/ic_backup_manager" />
    </PreferenceCategory>

    <PreferenceCategory android:title="其它">
        <Preference
            android:key="app_version"
            android:title="应用版本"
            android:selectable="false"
            app:icon="@drawable/ic_app_setting_app_version" />

        <Preference
            android:key="license"
            android:title="开源许可协议"
            app:icon="@drawable/ic_app_setting_license" />
    </PreferenceCategory>
</PreferenceScreen>