<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:id="@+id/play_bar_root"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_play_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="4dp">

        <FrameLayout
            android:id="@+id/fl_cover"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/background_cycle_bt">

            <ImageView
                android:id="@+id/iv_disc"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:src="@drawable/bg_playing_disc" />

            <ImageView
                android:id="@+id/iv_cover"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:background="@drawable/background_cycle_bt"
                android:scaleType="centerCrop"
                tools:src="@color/black" />

        </FrameLayout>

        <TextView
            android:id="@+id/tv_song_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:singleLine="true"
            android:textSize="14sp"
            tools:text="歌曲标题 - 艺术家"
            tools:textColor="@color/white" />

        <FrameLayout
            android:id="@+id/fl_play"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/play_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminate="false"
                android:progress="0"
                app:indicatorSize="28dp"
                app:trackThickness="2dp" />

            <ImageView
                android:id="@+id/iv_play"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_play_bar_play_pause_selector" />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/play_loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:visibility="gone"
                app:indicatorSize="22dp"
                app:trackThickness="2dp" />

        </FrameLayout>

        <ImageView
            android:id="@+id/iv_playlist"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_playlist" />

        <ImageView
            android:id="@+id/iv_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_close_white" />

    </LinearLayout>
</layout>
