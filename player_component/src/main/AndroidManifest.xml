<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.REORDER_TASKS" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application>
        <activity
            android:name=".ui.activities.player.PlayerActivity"
            android:configChanges="orientation|screenSize|screenLayout"
            android:screenOrientation="behind" />

        <activity
            android:name=".ui.activities.player_interceptor.PlayerInterceptorActivity"
            android:configChanges="orientation|screenSize"
            android:theme="@style/DialogActivityTheme" />
        <activity
            android:name=".ui.activities.overlay_permission.OverlayPermissionActivity"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|smallestScreenSize|uiMode"
            android:screenOrientation="portrait" />
        <activity
            android:name=".audio.ui.AudioPlayerActivity" />

        <service
            android:name=".audio.service.AudioPlayService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="false">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>
    </application>

</manifest>
